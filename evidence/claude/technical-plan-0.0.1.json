    "layered_architecture": {
      "router": "处理 HTTP 请求/响应，参数校验 (Pydantic)，调用 service 层，返回响应。不包含业务逻辑。",
      "service": "业务逻辑层。包含认证、授权检查、数据验证、状态流转规则。调用 repository 层访问数据库。",
      "repository": "数据访问层 (隐含在 SQLAlchemy session 操作中)。service 层通过 db: Session 参数直接操作模型。对于演示项目，不抽象独立 repository 层，service 直接使用 SQLAlchemy query。",
      "middleware": "认证中间件作为 FastAPI Depends 注入：get_current_user 从 JWT 解析用户，require_admin 检查角色。"
    },

    "api_endpoints": {
      "auth": [
        { "method": "POST", "path": "/api/auth/register", "handler": "register", "auth": false, "description": "注册新用户 (默认 role=user)" },
