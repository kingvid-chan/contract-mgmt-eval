    "component_tree": {
      "App": {
        "AuthProvider": {
          "BrowserRouter (basename='/projects/contract-mgmt-eval')": {
            "Routes": [
              "Route '/login' → LoginPage",
              "Route '/register' → RegisterPage",
              "Route '/reset-password' → PasswordResetPage",
              "Route '/' → ProtectedRoute → Layout": {
                "Outlet": [
                  "Route 'users' → AdminRoute → UserListPage",
                  "Route 'users/new' → AdminRoute → UserFormPage",
                  "Route 'users/:id/edit' → AdminRoute → UserFormPage",
                  "Route 'contracts' → ContractListPage",
                  "Route 'contracts/new' → ContractFormPage",
                  "Route 'contracts/:id' → ContractDetailPage",
                  "Route 'contracts/:id/edit' → ContractFormPage",
                  "Route '*' → NotFoundPage"
                ]
              }
            ]
          }
        }
      }
    },

    "routing_design": {
      "base_path": "/projects/contract-mgmt-eval",
      "routes": [
        { "path": "/login", "component": "LoginPage", "auth": false },
        { "path": "/register", "component": "RegisterPage", "auth": false },
        { "path": "/reset-password", "component": "PasswordResetPage", "auth": false },
        { "path": "/", "component": "ContractListPage (redirect)", "auth": true },
        { "path": "/users", "component": "UserListPage", "auth": true, "admin": true },
        { "path": "/users/new", "component": "UserFormPage", "auth": true, "admin": true },
        { "path": "/users/:id/edit", "component": "UserFormPage", "auth": true, "admin": true },
        { "path": "/contracts", "component": "ContractListPage", "auth": true },
        { "path": "/contracts/new", "component": "ContractFormPage", "auth": true },
        { "path": "/contracts/:id", "component": "ContractDetailPage", "auth": true },
        { "path": "/contracts/:id/edit", "component": "ContractFormPage", "auth": true },
        { "path": "*", "component": "NotFoundPage", "auth": false }
      ]
    },

    "auth_flow_frontend": {
      "context": "AuthContext 提供: user, token, isAuthenticated, isAdmin, login(), register(), logout()",
      "token_storage": "localStorage 存储 JWT token，页面刷新时从 localStorage 恢复",
      "axios_interceptor": "请求拦截器自动添加 Authorization: Bearer <token>；响应拦截器捕获 401 自动登出并跳转登录页",
      "protected_route": "ProtectedRoute 组件检查 isAuthenticated，未认证 → Navigate to /login",
      "admin_route": "AdminRoute 组件检查 isAdmin，非管理员 → 显示 403 页面"
    }
  },

