      ],
      "attachments": [
        { "method": "POST", "path": "/api/contracts/{contract_id}/attachments", "handler": "upload_attachment", "auth": true, "description": "上传附件 (PDF/Word, ≤10MB)" },
        { "method": "GET", "path": "/api/contracts/{contract_id}/attachments", "handler": "list_attachments", "auth": true, "description": "合同附件列表" },
        { "method": "GET", "path": "/api/attachments/{attachment_id}", "handler": "get_attachment_info", "auth": true, "description": "附件元信息" },
        { "method": "GET", "path": "/api/attachments/{attachment_id}/download", "handler": "download_attachment", "auth": true, "description": "下载附件文件" },
        { "method": "DELETE", "path": "/api/attachments/{attachment_id}", "handler": "delete_attachment", "auth": true, "description": "删除附件" }
      ],
      "system": [
        { "method": "GET", "path": "/healthz", "handler": "health_check", "auth": false, "description": "健康检查，返回 {\"status\":\"ok\"}" }
      ]
    },

