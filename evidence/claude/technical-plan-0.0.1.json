  "business_model": {
    "entity_relationships": {
      "description": "User 1:N Contract (created_by), Contract 1:N Attachment (contract_id), User 1:N AuditLog (user_id)",
      "cardinality": {
        "User → Contract": "一个用户可创建多个合同，一个合同属于一个创建者",
        "Contract → Attachment": "一个合同可有多个附件，一个附件属于一个合同",
        "User → AuditLog": "一个用户可有多条审计日志，一条日志属于一个用户"
      }
    },

    "status_flow": {
      "Contract": {
        "states": ["draft", "active", "terminated", "expired"],
        "transitions": [
          { "from": "draft", "to": "active", "action": "activate", "description": "激活合同，使其生效" },
          { "from": "active", "to": "terminated", "action": "terminate", "description": "提前终止合同" },
          { "from": "active", "to": "expired", "action": "expire", "description": "合同到期 (可手动标记或自动)" },
          { "from": "draft", "to": "deleted", "action": "delete", "description": "删除草稿合同 (物理删除)" }
        ],
        "constraints": [
          "draft 状态可删除，其他状态不可删除",
          "只能从 draft 转为 active",
          "只能从 active 转为 terminated 或 expired",
          "terminated 和 expired 是终态，不可再流转",
          "sign_date 在 active 时必填"
        ]
      },
      "User": {
        "states": ["active", "disabled"],
        "transitions": [
          { "from": "active", "to": "disabled", "action": "disable", "description": "管理员禁用用户" },
          { "from": "disabled", "to": "active", "action": "enable", "description": "管理员启用用户" }
        ]
      }
    },

