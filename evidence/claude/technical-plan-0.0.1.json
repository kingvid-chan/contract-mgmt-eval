  "database": {
    "engine": "SQLite",
    "orm": "SQLAlchemy 2.x ORM",
    "db_path": "backend/contract_mgmt.db",
    "migration_strategy": "create_all + seed — 演示项目不引入 Alembic。表结构变更时重新 create_all。",
    "foreign_keys": "PRAGMA foreign_keys = ON (SQLite 默认不启用外键约束，需显式开启)",

    "models": {
      "User": {
        "table": "users",
        "columns": {
          "id": "Integer, primary_key, autoincrement",
          "username": "String(50), unique, not null, index",
          "email": "String(100), unique, not null",
          "password_hash": "String(255), not null",
          "role": "String(10), default='user', check in ('admin','user')",
          "status": "String(10), default='active', check in ('active','disabled')",
          "created_at": "DateTime, default=utcnow",
          "updated_at": "DateTime, default=utcnow, onupdate=utcnow"
        },
        "relationships": [
          "contracts: relationship('Contract', back_populates='creator')",
          "audit_logs: relationship('AuditLog', back_populates='user')"
        ]
      },
      "Contract": {
        "table": "contracts",
        "columns": {
          "id": "Integer, primary_key, autoincrement",
          "title": "String(200), not null",
          "contract_no": "String(50), unique, not null, index",
          "party_a": "String(200), not null",
          "party_b": "String(200), not null",
          "amount": "Float, nullable, default=0.0",
          "status": "String(20), default='draft', check in ('draft','active','terminated','expired')",
          "sign_date": "Date, nullable",
          "expiry_date": "Date, nullable",
          "content": "Text, nullable, default='' (合同正文/备注)",
          "created_by": "Integer, ForeignKey('users.id'), not null",
          "created_at": "DateTime, default=utcnow",
          "updated_at": "DateTime, default=utcnow, onupdate=utcnow"
        },
        "relationships": [
          "creator: relationship('User', back_populates='contracts')",
          "attachments: relationship('Attachment', back_populates='contract', cascade='all, delete-orphan')"
        ]
      },
      "Attachment": {
        "table": "attachments",
        "columns": {
          "id": "Integer, primary_key, autoincrement",
          "contract_id": "Integer, ForeignKey('contracts.id', ondelete='CASCADE'), not null",
          "filename": "String(255), not null (存储后文件名 UUID)",
          "original_name": "String(255), not null (原始文件名)",
          "file_type": "String(20), not null, check in ('pdf','doc','docx')",
          "file_size": "Integer, not null (bytes)",
          "file_path": "String(500), not null (服务器存储路径)",
          "uploaded_by": "Integer, ForeignKey('users.id'), not null",
          "uploaded_at": "DateTime, default=utcnow"
        },
        "relationships": [
          "contract: relationship('Contract', back_populates='attachments')",
          "uploader: relationship('User')"
        ]
      },
      "AuditLog": {
        "table": "audit_logs",
        "columns": {
          "id": "Integer, primary_key, autoincrement",
          "user_id": "Integer, ForeignKey('users.id'), not null",
          "action": "String(50), not null (e.g. 'contract.create', 'user.delete')",
          "target_type": "String(50), nullable (e.g. 'contract', 'user', 'attachment')",
          "target_id": "Integer, nullable",
          "detail": "Text, nullable (JSON string with operation details)",
          "created_at": "DateTime, default=utcnow"
        },
        "relationships": [
          "user: relationship('User', back_populates='audit_logs')"
        ]
      }
    },

