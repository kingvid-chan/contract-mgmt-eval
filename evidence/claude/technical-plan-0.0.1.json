        { "method": "POST", "path": "/api/auth/password-reset", "handler": "request_password_reset", "auth": false, "description": "请求密码重置 (演示版：直接返回新密码，不发送邮件)" }
      ],
      "users": [
        { "method": "GET", "path": "/api/users", "handler": "list_users", "auth": true, "admin": true, "description": "获取用户列表" },
        { "method": "POST", "path": "/api/users", "handler": "create_user", "auth": true, "admin": true, "description": "管理员创建用户" },
        { "method": "GET", "path": "/api/users/me", "handler": "get_current_user_info", "auth": true, "description": "获取当前登录用户信息" },
        { "method": "GET", "path": "/api/users/{user_id}", "handler": "get_user", "auth": true, "admin": true, "description": "获取指定用户详情" },
        { "method": "PUT", "path": "/api/users/{user_id}", "handler": "update_user", "auth": true, "admin": true, "description": "更新用户信息" },
