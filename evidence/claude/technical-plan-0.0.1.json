  "product_flows_to_endpoints": {
    "registration_login": [
      { "step": "访问注册页 → 填写用户名/邮箱/密码 → 注册成功", "endpoint": "POST /api/auth/register", "frontend": "RegisterPage" },
      { "step": "登录 → 获取 JWT → 跳转首页", "endpoint": "POST /api/auth/login", "frontend": "LoginPage" },
      { "step": "登出 → 清除 token → 跳转登录页", "endpoint": "POST /api/auth/logout", "frontend": "Navbar logout button" },
      { "step": "忘记密码 → 输入邮箱 → 重置密码", "endpoint": "POST /api/auth/password-reset", "frontend": "PasswordResetPage" }
    ],
    "user_management": [
      { "step": "管理员查看用户列表", "endpoint": "GET /api/users", "frontend": "UserListPage" },
      { "step": "创建新用户", "endpoint": "POST /api/users", "frontend": "UserFormPage" },
      { "step": "编辑用户信息", "endpoint": "PUT /api/users/{id}", "frontend": "UserFormPage" },
      { "step": "启用/禁用用户", "endpoint": "PATCH /api/users/{id}/status", "frontend": "UserListPage" }
    ],
    "contract_management": [
      { "step": "查看合同列表 (搜索/筛选/分页)", "endpoint": "GET /api/contracts?search=&status=&page=&page_size=", "frontend": "ContractListPage" },
      { "step": "创建合同 (保存为草稿)", "endpoint": "POST /api/contracts", "frontend": "ContractFormPage" },
      { "step": "查看合同详情", "endpoint": "GET /api/contracts/{id}", "frontend": "ContractDetailPage" },
      { "step": "编辑合同", "endpoint": "PUT /api/contracts/{id}", "frontend": "ContractFormPage" },
      { "step": "删除合同", "endpoint": "DELETE /api/contracts/{id}", "frontend": "ContractListPage / ContractDetailPage" },
      { "step": "合同状态流转 (激活/终止/到期)", "endpoint": "PATCH /api/contracts/{id}/status", "frontend": "ContractDetailPage status action buttons" }
    ],
    "attachment_management": [
      { "step": "上传附件 (PDF/Word ≤10MB)", "endpoint": "POST /api/contracts/{id}/attachments", "frontend": "ContractDetailPage upload area" },
      { "step": "查看附件列表", "endpoint": "GET /api/contracts/{id}/attachments", "frontend": "ContractDetailPage attachment section" },
      { "step": "下载附件", "endpoint": "GET /api/attachments/{id}/download", "frontend": "ContractDetailPage download button" },
      { "step": "预览附件", "endpoint": "GET /api/attachments/{id}/download (Content-Disposition: inline)", "frontend": "新标签页打开" },
      { "step": "删除附件", "endpoint": "DELETE /api/attachments/{id}", "frontend": "ContractDetailPage delete button" }
    ],
    "error_boundary": [
      { "step": "未登录访问受保护页面", "behavior": "前端 ProtectedRoute 拦截 → 跳转 /login；后端 401" },
      { "step": "普通用户访问管理页面", "behavior": "前端 AdminRoute 拦截 → 显示 403；后端 403" },
      { "step": "上传非 PDF/Word 文件", "behavior": "后端校验文件扩展名和 MIME type → 400 错误" },
      { "step": "上传超大文件 (>10MB)", "behavior": "后端校验 Content-Length → 413 或 400 错误" },
      { "step": "重复合同编号", "behavior": "数据库 UNIQUE 约束 → 后端 409 Conflict" },
      { "step": "重复用户名/邮箱", "behavior": "数据库 UNIQUE 约束 → 后端 409 Conflict" },
      { "step": "修改非本人合同 (普通用户)", "behavior": "后端 permission check → 403 Forbidden" }
    ]
  },

  "security": {
    "jwt": {
      "algorithm": "HS256",
      "secret_key": "从环境变量 JWT_SECRET_KEY 读取，默认值用于开发",
      "token_expiry": "access_token 有效期 24 小时",
      "token_payload": "{ sub: user_id, username: username, role: role }",
      "extraction": "从 Authorization: Bearer <token> 请求头提取"
    },
    "password": {
      "hashing": "passlib bcrypt，12 rounds",
      "storage": "仅存储 password_hash，不存储明文密码",
      "validation": "注册时密码最少 6 字符"
    },
    "permission_middleware": {
      "get_current_user": "Depends 注入：解析 JWT → 查询数据库 → 检查用户状态 (disabled 则 403) → 返回 User 对象",
      "require_admin": "Depends 注入：调用 get_current_user → 检查 role == 'admin' → 否则 403"
    },
    "file_upload_security": {
      "max_size": "10 MB (10 * 1024 * 1024 bytes)",
      "allowed_extensions": [".pdf", ".doc", ".docx"],
      "allowed_mime_types": ["application/pdf", "application/msword", "application/vnd.openxmlformats-officedocument.wordprocessingml.document"],
      "validation": "扩展名 + MIME type 双重校验",
      "storage": "上传文件以 UUID 重命名存储，保留原始文件名在数据库 original_name 字段",
      "directory": "backend/uploads/，不要直接暴露为静态目录，通过 API 下载"
    },
    "audit_logging": {
      "events": [
        "user.login", "user.logout", "user.register",
