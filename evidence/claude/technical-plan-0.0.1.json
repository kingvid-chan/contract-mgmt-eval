        "contract.create", "contract.update", "contract.delete", "contract.status_change",
        "attachment.upload", "attachment.download", "attachment.delete"
      ],
      "implementation": "service 层在关键操作后调用 audit.log_action(db, user_id, action, target_type, target_id, detail)"
    }
  },

