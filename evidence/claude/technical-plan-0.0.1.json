      "contracts": [
        { "method": "GET", "path": "/api/contracts", "handler": "list_contracts", "auth": true, "description": "合同列表 (支持 ?search=&status=&page=&page_size=&sort_by=&sort_order=)" },
        { "method": "POST", "path": "/api/contracts", "handler": "create_contract", "auth": true, "description": "创建合同 (默认 status=draft)" },
        { "method": "GET", "path": "/api/contracts/{contract_id}", "handler": "get_contract", "auth": true, "description": "合同详情 (含附件列表)" },
