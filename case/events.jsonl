{"actor":"owner","anchor":{},"digest":"903ccba460ee0c10c752349a0b46f335455d169a323a2b3d5b4534508088119a","evidence":[],"id":"e000001","iteration":null,"payload":{"project_name":"合同管理系统-评测","text":"开发一个合同管理系统，需要以下核心功能：\n1. 用户登录与认证（支持注册、登录、登出、密码重置）\n2. 用户管理（管理员可查看/创建/编辑/禁用用户，分配角色权限）\n3. 合同管理（合同的创建、编辑、删除、列表、搜索、筛选、详情查看）\n4. 合同附件管理（支持 PDF 和 Word 格式上传、下载、预览、删除）\n\n技术要求：前端使用 React + TypeScript，后端使用 Python FastAPI，数据库使用 SQLite，整体需可运行。"},"prev":"GENESIS","recorded_by":"console-api","refs":{},"source":{"consumer_id":"boss","platform":"webui","request_id":"eval-20260618-001-create","signature":"6ac23c62dcdb5fa8d499b01c94489fad220ec533291418c9c5167edbce637c24"},"ts":"2026-06-18T09:49:39+00:00","type":"owner_input"}
{"actor":"hermes","anchor":{},"digest":"f819c97e3659a2194ae624413c5b569d1d1ee3872eba59330655664eaa6331ff","evidence":[],"id":"e000002","iteration":null,"payload":{"acceptance":{"browser_verification":"真实浏览器加载公网URL，检查CSS/JS/资源加载，Kimi视觉审查关键页面","hermes_verification":"Hermes 独立重跑完整测试、启动生产服务、走通关键流程","manual_path":"老板通过浏览器访问公网URL验证","public_preview":"部署至 aliyun-cowork http://120.24.117.67/projects/contract-mgmt-eval/","self_test":"Claude Code 自测覆盖登录、用户管理、合同CRUD、附件上传下载、权限边界"},"business_model":{"entities":[{"fields":["id","username","email","password_hash","role(admin/user)","status(active/disabled)","created_at","updated_at"],"name":"User"},{"fields":["id","title","contract_no","party_a","party_b","amount","status(draft/active/terminated/expired)","sign_date","expiry_date","created_by","created_at","updated_at"],"name":"Contract"},{"fields":["id","contract_id","filename","original_name","file_type(pdf/doc/docx)","file_size","uploaded_by","uploaded_at"],"name":"Attachment"},{"fields":["id","user_id","action","target_type","target_id","detail","created_at"],"name":"AuditLog"}],"relationships":["User 1:N Contract (created_by)","Contract 1:N Attachment","User 1:N AuditLog"],"status_flow":{"Contract":"draft → active → terminated | draft → active → expired"}},"data_constraints":{"auth":"演示性本地认证，不含 OAuth/SSO/LDAP","demo_accounts":"预置 admin/admin123 和 user/user123 演示账号","fake_data":"所有合同数据为虚构示例，不含真实个人信息或合同","no_real_data":"不得输入真实合同、真实身份证号、真实银行账号或任何真实敏感数据"},"deliverables":{"backend":"Python FastAPI REST API，JWT 认证，SQLite 数据库","database":"SQLite 数据库，含初始化 schema、种子数据(演示账号)","docs":"docs/architecture.md, docs/runbook.md, docs/decisions/, docs/iterations/0.0.N.md","frontend":"React + TypeScript SPA，包含登录/注册/用户管理/合同管理/附件管理页面","tests":"pytest 后端测试 + 前端关键流程自测脚本"},"product_flows":[{"name":"用户注册与登录","steps":["访问注册页 → 填写用户名/邮箱/密码 → 注册成功 → 登录","登录 → 访问受保护页面","登出 → 清除会话","忘记密码 → 输入邮箱 → 重置链接 → 新密码"]},{"name":"用户管理(管理员)","steps":["管理员登录 → 用户列表 → 查看详情","创建用户 → 填写信息/分配角色 → 保存","编辑用户 → 修改信息/角色 → 保存","禁用/启用用户"]},{"name":"合同管理","steps":["创建合同 → 填写合同信息 → 保存(草稿)","合同列表 → 搜索/筛选/分页","查看合同详情","编辑合同 → 修改信息 → 保存","删除合同","合同状态流转: 草稿→生效→终止/到期"]},{"name":"附件管理","steps":["合同详情页 → 上传附件(PDF/Word)","附件列表 → 下载附件","附件预览","删除附件"]},{"name":"异常与边界","steps":["未登录访问受保护页面 → 跳转登录","无权限操作 → 403","上传非 PDF/Word 文件 → 格式校验拒绝","上传超大文件 → 大小限制拒绝","重复合同编号 → 唯一性校验"]}],"project_name":"合同管理系统-评测","slug":"contract-mgmt-eval","summary":"基于 Web 的合同管理系统，支持用户认证、角色权限管理、合同全生命周期管理和附件管理","tech_defaults":{"backend":"Python 3.11+ FastAPI, SQLAlchemy, Alembic, python-jose(JWT), passlib","conda_env":"复用 ~/外部需求/.conda/codingagent；不存在则创建","database":"SQLite (开发/演示), 可迁移至 PostgreSQL","frontend":"React 18+ TypeScript, React Router, Axios"}},"prev":"903ccba460ee0c10c752349a0b46f335455d169a323a2b3d5b4534508088119a","recorded_by":"hermes","refs":{"source_event_id":"e000001"},"source":{},"ts":"2026-06-18T10:02:21+00:00","type":"requirement_defined"}
